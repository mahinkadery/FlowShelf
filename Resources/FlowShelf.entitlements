<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Personal/local build: not sandboxed so the Cleaner (v3) and file
	     references work across ~/Library. Screen Recording + Accessibility
	     are still gated by TCC and prompted at runtime. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
